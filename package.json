{
  "name": "@yoroi-classic/cip14-js",
  "version": "3.0.1",
  "description": "A Javascript library reference implementation for CIP14",
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=22.13.0 <23",
    "npm": "10.9.7"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json && npm run flowgen",
    "clean": "rm -rf ./dist/",
    "eslint": "eslint ./index.ts \"./tests/**/*.{test,spec}.ts\" ./tests/package-smoke.js",
    "flowgen": "flowgen ./dist/index.d.ts --no-inexact --add-flow-header -o dist/index.js.flow",
    "pack:dry-run": "npm pack --dry-run",
    "prepare": "npm run build",
    "test": "npm run typecheck && jest",
    "test:package": "npm run build && node ./tests/package-smoke.js",
    "typecheck": "tsc -p tsconfig.typecheck.json && tsc -p tsconfig.test.json",
    "verify": "npm run eslint && npm run test && npm run test:package && npm run pack:dry-run"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run verify"
    }
  },
  "license": "Apache-2.0 OR MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoroi-classic/cip14-js.git"
  },
  "author": "Yoroi Classic Contributors",
  "homepage": "https://github.com/yoroi-classic/cip14-js#readme",
  "dependencies": {
    "bech32": "2.0.0",
    "blake2b": "2.1.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "24.0.15",
    "eslint": "10.6.0",
    "eslint-plugin-jest": "29.15.4",
    "flowgen": "1.21.0",
    "globals": "17.7.0",
    "husky": "5.1.1",
    "jest": "30.4.2",
    "prettier": "3.9.5",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}

{
  "name": "@yoroi-classic/cip14-js",
  "version": "3.0.1",
  "description": "A Javascript library reference implementation for CIP14",
  "packageManager": "npm@10.9.7",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc && npm run flowgen",
    "clean": "rm -rf ./dist/",
    "eslint": "eslint ./index.ts ./tests/index.test.ts",
    "flowgen": "flowgen ./dist/index.d.ts --no-inexact --add-flow-header -o dist/index.js.flow",
    "pack:dry-run": "npm pack --dry-run",
    "prepare": "npm run build",
    "test": "tsc --noEmit && jest",
    "test:package": "npm run build && node ./tests/package-smoke.js",
    "verify": "npm run eslint && npm run test && npm run test:package && npm run pack:dry-run"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run verify"
    }
  },
  "license": "Apache-2.0 OR MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoroi-classic/cip14-js.git"
  },
  "author": "Yoroi Classic Contributors",
  "homepage": "https://github.com/yoroi-classic/cip14-js#readme",
  "dependencies": {
    "bech32": "2.0.0",
    "blake2b": "2.1.3"
  },
  "devDependencies": {
    "@types/eslint-plugin-prettier": "^3.1.0",
    "@types/jest": "27.0.1",
    "@typescript-eslint/eslint-plugin": "^4.31.1",
    "@typescript-eslint/parser": "^4.31.1",
    "eslint": "^7.32.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-config-airbnb-typescript": "^14.0.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-jest": "^24.4.0",
    "eslint-plugin-prettier": "^4.0.0",
    "flowgen": "1.14.1",
    "husky": "5.1.1",
    "jest": "30.4.2",
    "prettier": "^2.4.0",
    "ts-jest": "27.0.5",
    "tslint": "6.1.3",
    "typescript": "4.4.3"
  }
}
